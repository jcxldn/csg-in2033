<configuration>

    <!-- Include the shared common configuration -->
    <include resource="logs/config/logback-common.xml"/>

    <appender name="MEMBERS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/members.log</file>
        <append>true</append>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/members.log.%d{yyyy-MM-dd}.gz</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%date{HH:mm:ss.SSS} [Thread.%t] %-30c{1} %-5p %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="ac.csg.in2033.ipos.pu.members" level="DEBUG">
        <appender-ref ref="MEMBERS_FILE"/>
    </logger>

</configuration>