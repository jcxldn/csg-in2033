<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="200" prefWidth="300"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ac.csg.in2033.ipos.pu.gui.login.LoginSceneController">

    <padding>
        <Insets top="20" bottom="20" />
    </padding>

    <children>

        <HBox alignment="CENTER">
            <padding>
                <Insets bottom="20" />
            </padding>
            <Label fx:id="descriptionLabel" text="Customer Login" prefHeight="50" />
        </HBox>

        <!-- DETAILS -->

        <GridPane alignment="CENTER" hgap="10" vgap="10">

            <padding>
                <Insets bottom="20" />
            </padding>

            <!-- USERNAME -->

            <Label fx:id="emailLabel" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="0" />

            <TextField fx:id="emailTextField" GridPane.columnIndex="0" GridPane.rowIndex="1" />


            <!-- PASSWORD -->

            <Label fx:id="passwordLabel" text="Password:" GridPane.rowIndex="3" />

            <PasswordField fx:id="passwordField" GridPane.rowIndex="4" />

        </GridPane>

        <!-- BUTTONS -->

        <HBox alignment="CENTER">

            <padding>
                <Insets bottom="20" />
            </padding>

            <children>

                <!-- NON-COMMERCIAL REGISTER BUTTON -->
                <!-- TO BE MOVED -->

                <Button fx:id="registerButton" alignment="CENTER" defaultButton="true" mnemonicParsing="false" onAction="#OnNonCommercialRegisterButtonClick" text="Register" />

                <Region HBox.hgrow="SOMETIMES" maxWidth="10" />

                <!-- LOGIN BUTTON -->

                <Button fx:id="loginButton" alignment="CENTER" defaultButton="true" mnemonicParsing="false" onAction="#OnLoginButtonClick" text="Login" />
            </children>

        </HBox>

        <HBox alignment="CENTER">
            <padding>
                <Insets bottom="20" />
            </padding>

            <Label fx:id="notifLabel" />
        </HBox>



        <!-- COMMERCIAL REGISTER LINK -->

        <Hyperlink fx:id="registerLink" alignment="CENTER" mnemonicParsing="false" onAction="#OnCommercialRegisterLinkClick" text="Looking to register as a merchant?" />
    </children>
</VBox>
