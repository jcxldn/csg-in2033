<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.text.Text?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<VBox alignment="TOP_CENTER" prefHeight="600" prefWidth="800"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ac.csg.in2033.ipos.pu.gui.dashboard.NC_DashboardSceneController">

    <padding>
        <Insets top="10" bottom="10" left="10" right="10"/>
    </padding>

    <HBox alignment="CENTER" spacing="20">
        <padding>
            <Insets top="10" bottom="10" left="10" right="10"/>
        </padding>

        <!-- WELCOME MESSAGE -->

        <Label text="Welcome, User!" />

        <!-- PROFILE BUTTON -->
        <!-- MOVE TO NAV HEADER IN FUTURE -->

        <Button text="Profile" onAction="#onProfileClick" />
    </HBox>

    <!-- SEARCH BAR -->
    <HBox alignment="CENTER" spacing="10">
        <TextField fx:id="searchField" promptText="Search products..." />
        <Button text="Search" onAction="#onSearchClick" />
    </HBox>

    <!-- PRODUCT FEED -->
    <HBox alignment="CENTER">
        <padding>
            <Insets top="10" bottom="10" left="10" right="10"/>
        </padding>

        <fx:include source="product-feed.fxml" />
    </HBox>
</VBox>